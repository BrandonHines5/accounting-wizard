# CRITICAL — real financial data must never be committed
# (data/* not data/ so the README below can be re-included; everything else
# inside is still ignored)
data/*
output/
*.xlsx
*.xls
*.csv
*.pdf
*.qbb
*.qbw
*.env
.env*
# Check/statement images carry account numbers + signatures — never commit them.
*.jpg
*.jpeg
*.png
*.tif
*.tiff
*.gif
*.webp
*.heic

# Synthetic test fixtures + the runnable example dataset are safe (fictional
# data) and explicitly re-included
!tests/fixtures/*.csv
!examples/**/*.csv

# Review-UI brand icons (favicon + home-screen bookmark image). Safe, synthetic
# assets — re-included by exact path so the *.png financial-image guard stays tight.
!review-ui/app/apple-icon.png
!review-ui/public/icon-192.png
!review-ui/public/icon-512.png

# Placeholder README + per-entity drop folders exist in fresh clones,
# but every real file dropped inside them stays ignored
!data/README.md
!data/*/
data/*/*
!data/*/.gitkeep

# Tier 4 bank-account registry — the real one references account structure and
# env-secret names; keep it local. The committed template is bank_accounts.example.yaml.
config/bank_accounts.yaml

# SharePoint pull config — references real folder paths; keep it local.
# The committed template is sharepoint.example.yaml.
config/sharepoint.yaml

# Python
__pycache__/
*.pyc
.pytest_cache/
.venv/
venv/
