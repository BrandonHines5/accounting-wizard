# CRITICAL — real financial data must never be committed
# (data/* not data/ so the README below can be re-included; everything else
# inside is still ignored)
data/*
output/
*.xlsx
*.xls
*.csv
*.pdf
*.qbb
*.qbw
*.env
.env*

# Synthetic test fixtures are safe and explicitly re-included
!tests/fixtures/*.csv

# Placeholder README so data/ exists in fresh clones (contents stay ignored)
!data/README.md

# Python
__pycache__/
*.pyc
.pytest_cache/
.venv/
venv/
